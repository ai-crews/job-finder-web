<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Job Finder</title>

    <link rel="icon" href="/jobfinderlogo.jpg" type="image/jpeg">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Alatsi&display=swap" rel="stylesheet">

    <script src="https://cdn.tailwindcss.com"></script>

    <script async src="https://www.googletagmanager.com/gtag/js?id=<%= gaId %>"></script>
    <script>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());

        // debug_mode: true 설정으로 로컬(localhost)에서도 실시간 데이터 확인이 가능
        gtag('config', '<%= gaId %>', { 'debug_mode': true });
    </script>
</head>
<body class="bg-[#F9FAFB]">
<header class="bg-[#3E5F44] text-white pt-10 md:pt-12 pb-8 text-center px-5">
    <h1 class="text-3xl md:text-4xl font-bold mb-2 md:mb-3">수시 채용공고 확인</h1>
    <p class="text-sm md:text-xl font-light opacity-90 break-all">'바로가기'를 누르면 해당 채용공고로 이동합니다.</p>

    <div class="max-w-md mx-auto mt-6 relative text-gray-900">
        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
            <span class="text-gray-500">🔍</span>
        </div>
        <input type="text" id="search-input" onkeyup="handleSearch()"
               class="w-full pl-11 pr-4 py-3 rounded-full border-none focus:ring-2 focus:ring-[#FDE68A] shadow-md outline-none text-sm md:text-base transition-shadow"
               placeholder="기업명 또는 공고명을 검색해보세요">
    </div>

</header>

<section class="max-w-5xl mx-auto px-4 mt-4 md:mt-8 mb-6">
    <div class="flex justify-start md:justify-center gap-2 md:gap-3 overflow-x-auto no-scrollbar pb-2">
        <button id="btn-all" onclick="filterJobs('all', this)"
                class="filter-btn whitespace-nowrap px-5 py-2 bg-[#FEF9C3] border border-[#FDE68A] rounded-full text-xs md:text-sm font-medium hover:bg-[#FDE68A] transition-all shrink-0">
            전체
        </button>
        <% ['ML엔지니어', '데이터엔지니어', '데이터분석가', 'AI리서치', 'AI기획자'].forEach(tag => { %>
            <button onclick="filterJobs('<%= tag %>', this)"
                    class="filter-btn whitespace-nowrap px-5 py-2 bg-[#FEF9C3] border border-[#FDE68A] rounded-full text-xs md:text-sm font-medium hover:bg-[#FDE68A] transition-all shrink-0">
                <%= tag %>
            </button>
        <% }) %>
    </div>
</section>

<main class="max-w-5xl mx-auto px-4 pb-4 min-h-[50vh]" id="job-list">
    <% if (jobs && jobs.length > 0) { %>
        <%# 1. 공고가 있을 때: 기존처럼 리스트 출력 %>
        <% jobs.forEach((job, index) => { %>
            <div class="job-card bg-white border border-gray-100 rounded-2xl p-3 md:p-8 mb-4 md:mb-6 flex flex-row items-center gap-2 md:gap-6 shadow-sm transition-all"
                 data-company="<%= job[0] %>"
                 data-title="<%= job[1] %>"
                 data-job="<%= job[2].replace(/[\[\]'"]/g, '') %>"
                 data-date="<%= job[4] %>"
                 data-index="<%= index %>">

                <div class="w-16 h-16 md:w-28 md:h-28 bg-[#F9FAFB] flex items-center justify-center rounded-xl md:rounded-2xl flex-shrink-0 overflow-hidden border border-gray-100">
                    <% if (job[6] && job[6].trim() !== '') { %>
                        <img src="<%= job[6] %>" alt="<%= job[0] %> 로고" class="w-full h-full object-contain p-1.5 md:p-2"
                             onerror="this.style.display='none'; this.nextElementSibling.classList.remove('hidden');">
                        <span class="hidden text-gray-400 font-extrabold text-[10px] md:text-lg text-center break-keep px-1"><%= job[0] %></span>
                    <% } else { %>
                        <div class="w-full h-full bg-[#F9FAFB] flex items-center justify-center p-1.5 md:p-2">
                            <span class="text-gray-400 font-extrabold text-[10px] md:text-lg text-center break-all px-1"><%= job[0] %></span>
                        </div>
                    <% } %>
                </div>

                <div class="flex-1 text-left min-w-0">
                    <h2 class="text-base md:text-3xl font-bold text-gray-900 mb-0.5 md:mb-2 truncate"><%= job[0] %></h2>
                    <div class="space-y-0.5 md:space-y-1 text-[11px] md:text-lg">
                        <p class="text-gray-700 truncate"><span class="font-bold">공고명</span> <%= job[1] %></p>
                        <p class="text-gray-700 truncate"><span class="font-bold">직무명</span> <%= job[2].replace(/[\[\]'"]/g, '') %></p>
                    </div>
                    <div class="mt-1.5 md:mt-4 flex flex-wrap items-center gap-1 md:gap-3 overflow-hidden">
                        <span class="bg-[#FEF9C3] text-[#854D0E] px-1.5 md:px-3 py-0.5 md:py-1 rounded text-[10px] md:text-xs font-bold whitespace-nowrap"><%= job[3].replace(/[\[\]'"]/g, '') %></span>
                        <span class="bg-[#FFEDD5] text-[#9A3412] px-1.5 md:px-2 py-0.5 md:py-1 rounded text-[10px] md:text-xs font-bold whitespace-nowrap truncate max-w-full">
                            🔥 <%= job[7] || 0 %>번 확인된 채용공고 입니다! 🔥
                        </span>
                    </div>
                </div>

                <a href="<%= job[5] %>"
                   target="_blank"
                   onclick="trackJobClick('<%= job[0].replace(/['"]/g, '') %>', '<%= job[2].replace(/[\[\]'"]/g, '') %>', '<%= job[1].replace(/['"]/g, '') %>', 'web', 'web')"
                   class="whitespace-nowrap text-center border-2 border-gray-200 px-2.5 py-1.5 md:px-8 md:py-3 rounded-lg md:rounded-xl font-bold text-[11px] md:text-base text-gray-700 hover:bg-gray-50 transition-colors shrink-0">
                    바로가기
                </a>
            </div>
        <% }) %>
    <% } else { %>
        <%# 2. 공고가 없을 때: 안내 메시지 출력 %>
        <div class="flex flex-col items-center justify-center py-20 bg-white border border-dashed border-gray-200 rounded-3xl">
            <div class="text-6xl mb-4">☕</div>
            <p class="text-xl font-bold text-gray-900 mb-2">현재 등록된 공고가 없습니다.</p>
            <p class="text-gray-500 text-center">나중에 다시 방문해 주세요!<br>새로운 공고를 준비 중입니다.</p>
        </div>
    <% } %>
        <div id="no-filter-results" class="hidden flex flex-col items-center justify-center py-20 bg-white border border-dashed border-gray-200 rounded-3xl">
            <div class="text-6xl mb-4">🔍</div>
            <p class="text-xl font-bold text-gray-900 mb-2">해당 직무의 공고가 현재 없습니다.</p>
            <p class="text-gray-500 text-center px-4">다른 직무를 선택하시거나<br class="md:hidden"> 전체 공고를 확인해 보세요!</p>
        </div>
</main>

<div id="scroll-sentinel" class="h-10 mb-20"></div>

<footer class="bg-[#3E5F44] text-white py-16 text-center">
    <h2 class="text-5xl md:text-7xl mb-8 tracking-tighter" style="font-family: 'Alatsi', sans-serif;">
        JOB FINDER
    </h2>

    <div class="space-y-6">
        <p class="font-bold text-lg md:text-xl opacity-90">
            당신의 성공적인 커리어를 응원합니다
        </p>

        <div class="mt-8">
            <a href="https://www.notion.so/JOB-FINDER-314ba24dd83080839d3ad0a5454f9410?source=copy_link"
               target="_blank"
               class="inline-block px-6 py-3 border border-white/40 rounded-full text-sm md:text-base font-medium hover:bg-white hover:text-[#3E5F44] transition-all duration-300">
                JOB FINDER를 만든 사람들 알아보기
            </a>
        </div>
    </div></footer>


<script>
    let currentVisibleCount = 10; // 처음에 보여줄 카드 개수
    const itemsPerPage = 10;      // 스크롤할 때마다 추가로 보여줄 개수
    let currentCategory = 'all';

    // 1. 카드를 화면에 그리는 함수 (페이지 번호 대신 개수 기반으로 변경)
    function renderItems() {
        const allCards = Array.from(document.querySelectorAll('.job-card'));
        const matchedCards = allCards.filter(card => !card.classList.contains('filtered-out'));

        // 필터 결과 없음 메시지 처리
        const noResultMsg = document.getElementById('no-filter-results');
        if (matchedCards.length === 0) {
            if (noResultMsg) {
                noResultMsg.classList.remove('hidden');
                noResultMsg.classList.add('flex');
            }
        } else {
            if (noResultMsg) {
                noResultMsg.classList.add('hidden');
                noResultMsg.classList.remove('flex');
            }
        }

        // 일단 모든 카드를 숨김
        allCards.forEach(card => card.style.display = 'none');

        // 필터링된 카드 중 0번부터 currentVisibleCount 개수까지만 보여줌
        matchedCards.slice(0, currentVisibleCount).forEach(card => {
            card.style.display = 'flex'; // 모바일 가로 배치를 위해 flex 유지
        });

        // 더 보여줄 카드가 남아있으면 감지용 박스 켜고, 다 보여줬으면 끔
        const sentinel = document.getElementById('scroll-sentinel');
        if (sentinel) {
            if (currentVisibleCount < matchedCards.length) {
                sentinel.style.display = 'block';
            } else {
                sentinel.style.display = 'none';
            }
        }
    }

    // 2. 무한 스크롤 감지 설정 (Intersection Observer)
    function setupInfiniteScroll() {
        const observer = new IntersectionObserver((entries) => {
            // 감지용 박스가 화면에 보이면 loadMore 실행
            if (entries[0].isIntersecting) {
                loadMore();
            }
        }, { rootMargin: "150px" }); // 바닥에 닿기 150px 전에 미리 로드

        const sentinel = document.getElementById('scroll-sentinel');
        if (sentinel) {
            observer.observe(sentinel);
        }
    }

    // 3. 카드를 더 불러오는 함수
    function loadMore() {
        const allCards = Array.from(document.querySelectorAll('.job-card'));
        const matchedCards = allCards.filter(card => !card.classList.contains('filtered-out'));

        // 보여줄 카드가 더 남아있을 때만 개수를 늘리고 다시 렌더링
        if (currentVisibleCount < matchedCards.length) {
            currentVisibleCount += itemsPerPage;
            renderItems();
        }
    }


    // 1. 카테고리(직무) 버튼 클릭 시 실행
    function filterJobs(category, element) {
        currentCategory = category; // 클릭한 카테고리로 업데이트

        // 버튼 디자인 변경 (선택된 버튼 강조)
        const buttons = document.querySelectorAll('.filter-btn');
        buttons.forEach(btn => {
            btn.classList.remove('bg-[#FDE68A]', 'border-yellow-500', 'font-bold');
            btn.classList.add('bg-[#FEF9C3]', 'border-[#FDE68A]', 'font-medium');
        });
        element.classList.remove('bg-[#FEF9C3]', 'font-medium');
        element.classList.add('bg-[#FDE68A]', 'border-yellow-500', 'font-bold');

        // 필터 로직 실행
        applyAllFilters();
    }

    // 2. 검색창에 타자를 칠 때마다 실행 (onkeyup)
    function handleSearch() {
        applyAllFilters();
    }

    // 3. 직무 + 검색어 둘 다 만족하는 것만 남기기
    function applyAllFilters() {
        // 검색창의 텍스트 가져오기 (대소문자 무시)
        const keyword = document.getElementById('search-input').value.toLowerCase().trim();
        const cards = document.querySelectorAll('.job-card');

        // 필터 조건이 바뀌었으니, 화면에 보여줄 카드 개수를 다시 10개로 초기화
        currentVisibleCount = itemsPerPage;

        cards.forEach(card => {
            const jobType = card.getAttribute('data-job') || '';
            const companyName = (card.getAttribute('data-company') || '').toLowerCase();

            // 주석 수정됨: HTML 카드에 data-title 속성을 잘 넣으셨다면 아래 줄이 정상 작동합니다!
            const jobTitle = (card.getAttribute('data-title') || '').toLowerCase();

            // [조건 A] 직무 카테고리가 일치하는가?
            const matchesCategory = (currentCategory === 'all' || jobType.includes(currentCategory));

            // [조건 B] 검색어(기업명/공고명)가 일치하는가?
            const matchesSearch = (keyword === '' || companyName.includes(keyword) || jobTitle.includes(keyword));

            // 조건 A와 조건 B를 "모두" 만족(&&)해야만 화면에 보여줌
            if (matchesCategory && matchesSearch) {
                card.classList.remove('filtered-out');
            } else {
                card.classList.add('filtered-out');
            }
        });

        // 렌더링 함수 호출 (화면에 그리기)
        renderItems();
    }

    function sortJobs() {
        const container = document.getElementById('job-list');
        const cards = Array.from(container.getElementsByClassName('job-card'));

        // 무조건 마감기한(data-date) 순으로 정렬
        cards.sort((a, b) => {
            const dateA = a.getAttribute('data-date');
            const dateB = b.getAttribute('data-date');
            return dateA.localeCompare(dateB); // 오름차순 (빨리 마감되는 순)
        });

        // 정렬된 순서대로 DOM에 다시 배치
        cards.forEach(card => container.appendChild(card));
    }

    // index.ejs의 <script> 태그 안에 추가
    window.onload = () => {
        const urlParams = new URLSearchParams(window.location.search);
        const dest = urlParams.get('url');

        // 🎯 URL에서 source 파라미터를 읽어오는 붑분 (없으면 기본값 'web')
        // n8n 메일 링크에는 ?source=email 이 붙어있어야 합니다.
        const source = urlParams.get('source') || 'web';

        //  URL에서 user_id 파라미터 읽어오기
        const userId = urlParams.get('user_identifier') || 'web';

        if (dest) {
            const company = urlParams.get('company');
            const jobTitle = urlParams.get('job_title');
            const recruitment = urlParams.get('recruitment_title');

            // 🎯 2. 추적 함수에 source 정보를 함께 전달
            trackJobClick(company, jobTitle, recruitment, source, userId);

            const mainElement = document.getElementById('job-list');
            if (mainElement) {
                mainElement.innerHTML = `
            <div style="text-align:center; padding:100px 20px;">
                <h2 style="font-size:24px; font-weight:bold; color:#333;">${company} 공고로 이동 중입니다...</h2>
                <p style="color:#666; margin-top:10px;">유입 경로: ${source === 'email' ? '📧 메일' : '🌐 웹사이트'}</p>
                <p style="color:#666; margin-top:10px;">잠시만 기다려 주세요. 🎸</p>
            </div>`;
            }
            // 헤더와 푸터 숨기기
            const header = document.querySelector('header');
            const footer = document.querySelector('footer');
            const filterSection = document.querySelector('.flex.justify-start'); // 필터 버튼 영역
            const sortSelect = document.querySelector('#sort-select')?.parentElement; // 정렬 셀렉트 박스

            if (header) header.style.display = 'none';
            if (footer) footer.style.display = 'none';
            if (filterSection) filterSection.style.display = 'none';
            if (sortSelect) sortSelect.style.display = 'none';

            setTimeout(() => {
                window.location.href = dest;
            }, 500);

            return;
        }

        if (!dest) {
            sortJobs();   // 1. 페이지 로드 시 정렬 먼저 하고
            renderItems(); // 2. 그 다음 화면에 그리기
            setupInfiniteScroll(); //무한스크롤 초기화
        }
    };

    // 클릭 추적 함수 (기존과 동일)
    function trackJobClick(company, job, recruitment, clickSource, userId) {
        gtag('event', 'click_job_link', {
            'company': company,
            'job_title': job,
            'recruitment_title': recruitment,
            'click_source': clickSource, // GA4에서 이 값으로 필터링 가능
            'user_identifier': userId, //유저 별 클릭 활동 분석
            'value': 1
        });

        // 서버에 클릭 알림 (이 부분이 정확해야 합니다)
        fetch('/api/jobs/click', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json' // JSON 형식임을 명시
            },
            body: JSON.stringify({
                recruitment_title: recruitment,
                company: company
            })
        })
            .then(res => res.json())
            .then(data => console.log('성공:', data))
            .catch(err => console.error('에러:', err));
    }
</script>
</body>
</html>